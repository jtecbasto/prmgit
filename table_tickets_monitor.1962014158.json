	"eventHandlers": [
		{
			"eventId": "EVENT_BEFOREPROCESS_LIST",
			"pageType": "list",
			"code": "if (postvalue(\"ajax\") == \"ticketsPendientes\") {\n    header(\"Content-Type: application/json; charset=UTF-8\");\n    header(\"Cache-Control: no-cache, no-store, must-revalidate\");\n    header(\"Pragma: no-cache\");\n    header(\"Expires: 0\");\n\n    $idggtipoventa = isset($_SESSION[\"idggtipoventa\"]) ? intval($_SESSION[\"idggtipoventa\"]) : 0;\n    $userId = Security::getUserName();\n    $ticketSession = isset($_SESSION[\"ticket_session\"]) ? $_SESSION[\"ticket_session\"] : \"\";\n\n    $userIdEsc = db_addslashes($userId);\n    $ticketSessionEsc = db_addslashes($ticketSession);\n\n    $sql = \"\n        SELECT COUNT(*) AS total\n        FROM tickets_atencion_domicilio tad\n        LEFT JOIN tiposventa tv ON tad.idtipoventa = tv.idtipoventa\n        LEFT JOIN gtiposventa gtv ON tv.idgtipoventa = gtv.idgtipoventa\n        WHERE gtv.idggtipoventa = \".$idggtipoventa.\"\n          AND NOT EXISTS (\n                SELECT 1\n                FROM solicitudes s\n                WHERE s.idticket = tad.id\n          )\n          AND NOT EXISTS (\n                SELECT 1\n                FROM tickets_reservados_tmp rr\n                WHERE rr.idticket = tad.id AND rr.expires_at >= NOW()\n                  AND NOT (\n                        rr.usuario = '\".$userIdEsc.\"'\n                    AND rr.sesion_id = '\".$ticketSessionEsc.\"'\n                  )\n          )\n    \";\n\n    $rs = db_query($sql, $conn);\n    $row = $rs ? db_fetch_array($rs) : false;\n    $total = $row ? intval($row[\"total\"]) : 0;\n\n    echo my_json_encode(array(\n        \"ok\" => true,\n        \"total\" => $total\n    ));\n    exit();\n}\n\n/* opcional: bloquear acceso normal a la página */\nif (!postvalue(\"ajax\")) {\n    echo \"Acceso no válido\";\n    exit();\n}\n\n"
		}
	],
