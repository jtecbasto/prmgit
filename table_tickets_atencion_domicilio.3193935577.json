{
	"sql": "SELECT\r\ntad.id,\r\ntad.fecha,\r\ntad.idcliente,\r\nc.nombre_completo,\r\ntad.idtipoventa,\r\ntv.tipoventa,\r\ntad.idplan,\r\np.plan,\r\ntad.idproducto,\r\nr.descripcion equipo,\r\ntad.plazo,\r\ntad.usuario,\r\ntad.idtienda,\r\nt.tienda,\r\ntad.fechacaptura\r\nFROM tickets_atencion_domicilio tad\r\nleft join clientes c on tad.idcliente = c.idcliente\r\nleft join tiposventa tv on tad.idtipoventa = tv.idtipoventa\r\nleft join planes p on tad.idplan = p.idplan\r\nleft join productos r on tad.idproducto=r.idproducto\r\nleft join tiendas t on tad.idtienda = t.idtienda",
